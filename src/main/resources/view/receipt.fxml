<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      spacing="10" alignment="CENTER">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <Label text="%label.receipt" style="-fx-font-size: 16;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="%col.name" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="supplierCombo" promptText="%menu.suppliers"
                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="%col.date" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <DatePicker fx:id="receiptDate" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <TableView fx:id="itemsTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="colProduct" text="%col.product" prefWidth="150"/>
            <TableColumn fx:id="colQuantity" text="%col.quantity" prefWidth="80"/>
            <TableColumn fx:id="colPrice" text="%col.price" prefWidth="100"/>
            <TableColumn fx:id="colCell" text="%col.cell" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="%button.addItem" onAction="#addItem"/>
        <Button text="%button.removeItem" onAction="#removeItem"/>
        <Button text="%button.save" onAction="#saveReceipt"/>
    </HBox>
</VBox>