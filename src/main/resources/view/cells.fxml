<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      spacing="10" alignment="CENTER">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <Label text="%label.cells" style="-fx-font-size: 16;"/>

    <TableView fx:id="cellsTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="colZone" text="%col.zone" prefWidth="80"/>
            <TableColumn fx:id="colRow" text="%col.row" prefWidth="80"/>
            <TableColumn fx:id="colRack" text="%col.rack" prefWidth="100"/>
            <TableColumn fx:id="colNumber" text="%col.cellNumber" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="%button.add" onAction="#addCell"/>
        <Button text="%button.edit" onAction="#editCell"/>
        <Button text="%button.delete" onAction="#deleteCell"/>
    </HBox>
</VBox>